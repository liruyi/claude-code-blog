---
const base = import.meta.env.BASE_URL
---

<footer class="border-t border-slate-200 dark:border-slate-700 py-8 mt-12">
  <div class="max-w-6xl mx-auto px-4 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-slate-600 dark:text-slate-400">
    <p>© 2024 Claude Code Blog. 基于 Astro 构建.</p>
    <div class="flex items-center gap-4">
      <a href="https://github.com/your-username/claude-code-blog" class="hover:text-primary transition-colors">
        GitHub
      </a>
      <a href={`${base}/rss.xml`} class="hover:text-primary transition-colors">
        RSS
      </a>
    </div>
  </div>
</footer>
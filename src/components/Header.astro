---
import ThemeToggle from './ThemeToggle.astro'
const base = import.meta.env.BASE_URL
---

<header class="sticky top-0 z-40 bg-white/80 dark:bg-slate-900/80 backdrop-blur border-b border-slate-200 dark:border-slate-700">
  <nav class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between">
    <a href={`${base}/`} class="flex items-center gap-2 font-semibold text-slate-900 dark:text-slate-100">
      <svg class="w-6 h-6" viewBox="0 0 32 32">
        <rect width="32" height="32" rx="4" fill="#667eea"/>
        <text x="16" y="22" text-anchor="middle" font-family="monospace" font-size="16" fill="white">C</text>
      </svg>
      <span class="hidden sm:inline">Claude Code Blog</span>
    </a>

    <div class="flex items-center gap-4">
      <a href={`${base}/search`} class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="搜索">
        <svg class="w-5 h-5 text-slate-600 dark:text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
        </svg>
      </a>

      <a href={`${base}/rss.xml`} class="p-2 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors" aria-label="RSS">
        <svg class="w-5 h-5 text-slate-600 dark:text-slate-400" fill="currentColor" viewBox="0 0 24 24">
          <path d="M6.18 15.18a2.18 2.18 0 01-2.18 2.18C2.97 17.36 2 16.39 2 15.18C2 13.97 2.97 13 4.18 13s2.18.97 2.18 2.18zM12 17.36c0-3.08-2.5-5.58-5.58-5.58v2.83c1.52 0 2.75 1.23 2.75 2.75H12zM12 10c-5.05 0-9.18 4.13-9.18 9.18h2.83c0-3.52-2.86-6.35-6.35-6.35V10z"/>
        </svg>
      </a>

      <ThemeToggle />
    </div>
  </nav>
</header>
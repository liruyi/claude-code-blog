---
import { getAllSeriesMeta } from '../utils/series'

const seriesList = getAllSeriesMeta()
const totalArticles = 54
---

<section class="relative bg-gradient-to-br from-primary/10 via-purple-500/5 to-transparent py-16 sm:py-24">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h1 class="text-4xl sm:text-5xl font-bold text-slate-900 dark:text-slate-100 mb-4">
      Claude Code 源码深度解析
    </h1>
    <p class="text-lg sm:text-xl text-slate-600 dark:text-slate-400 mb-6">
      深入探索 Anthropic 官方 CLI 工具的设计哲学与实现细节
    </p>
    <div class="flex items-center justify-center gap-6 text-sm text-slate-500 dark:text-slate-400">
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
        </svg>
        {seriesList.length} 个系列
      </span>
      <span class="flex items-center gap-1">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        {totalArticles} 篇文章
      </span>
    </div>
  </div>
</section>
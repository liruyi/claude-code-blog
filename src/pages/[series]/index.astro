---
import Layout from '../../components/Layout.astro'
import ArticleCard from '../../components/ArticleCard.astro'
import { getSeriesMeta, getSeriesArticles } from '../../utils/series'

export async function getStaticPaths() {
  return [
    { params: { series: 'blog' } },
    { params: { series: 'extension' } },
    { params: { series: 'performance' } },
    { params: { series: 'security' } },
    { params: { series: 'ux' } },
  ]
}

const { series } = Astro.params
const seriesMeta = getSeriesMeta(series)
const articles = await getSeriesArticles(series)
---

<Layout title={seriesMeta?.title} description={seriesMeta?.description}>
  <section class="max-w-4xl mx-auto px-4 py-12">
    <header class="mb-8">
      <div class="w-16 h-16 rounded-xl mb-6 flex items-center justify-center" style={`background-color: ${seriesMeta?.color}20;`}>
        <div class="w-8 h-8 rounded-lg" style={`background-color: ${seriesMeta?.color};`}></div>
      </div>
      <h1 class="text-3xl font-bold text-slate-900 dark:text-slate-100 mb-3">
        {seriesMeta?.title}
      </h1>
      <p class="text-slate-600 dark:text-slate-400">
        {seriesMeta?.description}
      </p>
      <div class="text-sm text-slate-500 dark:text-slate-500 mt-4">
        {articles.length} 篇文章
      </div>
    </header>

    <div class="space-y-4">
      {articles.map((article) => (
        <ArticleCard title={article.data.title} description={article.data.description} publishDate={article.data.publishDate} series={series} slug={article.slug} />
      ))}
    </div>
  </section>
</Layout>